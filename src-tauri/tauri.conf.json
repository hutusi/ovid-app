{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ovid",
  "version": "0.9.5",
  "identifier": "com.hutusi.ovid",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ovid",
        "width": 1200,
        "height": 800,
        "minWidth": 700,
        "minHeight": 500,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "useLocalToolsDir": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "upgradeCode": "560a52eb-70f5-589f-b4a4-17c060721c9c"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://hutusi.github.io/ovid/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGQ0I1MUQ4MEQzQjQ0NTkKUldSWlJEc04yRkhMVDM1Ukc2V3ZpdTIxNlVtdnRMQm5mRHZJTEZxb3ZselZMNkNUU0tSOUc3MEIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
